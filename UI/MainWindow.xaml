<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UltimateTuner" Height="450" Width="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Background="#222" >
            <Button Content="Windows" Margin="5" />
            <Button Content="GPU" Margin="5" />
            <Button Content="CPU" Margin="5" />
            <Button Content="Network" Margin="5" />
            <Button Content="Devices" Margin="5" />
        </StackPanel>
        <TextBox x:Name="LogBox" Grid.Column="1" Margin="5" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" />
    </Grid>
</Window>
